{
  "name": "obsidian-jira-tiles",
  "version": "0.1.2",
  "description": "Embed live Atlassian Jira Cloud issues as rich tiles in Obsidian notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "dev:preview": "node esbuild.config.mjs --serve",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs --production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "jira",
    "atlassian"
  ],
  "author": "Sidd Shah",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "obsidian": "^1.11.4",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
